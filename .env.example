# =============================================================================
# VitalSync Medical API — Environment Variables
# =============================================================================
# Copy this to .env and fill in production values.
# NEVER commit .env to version control.
# =============================================================================

# Database
DB_PASSWORD=changeme_in_production
DATABASE_URL=postgresql://vitalsync:changeme_in_production@localhost:5432/vitalsync

# Authentication
JWT_SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# PHI Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Application
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000
